{
  "compilerOptions": {
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "strict": true,
    "target": "esnext",
    "module": "esnext",
    "jsx": "react-jsx",
    "baseUrl": "./",
    "lib": ["dom", "dom.iterable", "esnext"],
    "paths": {
      "*": ["src/*"]
    }
  },
  "include": ["src", "vite-env.d.ts"],
  "exclude": [
    "../node_modules"
  ]
}
