{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "statusCode": 308,
      "regex": "^(?!/_next)(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/(?:/)?$"
    },
    {
      "source": "/products/product/:slug",
      "destination": "/en/product/:slug",
      "statusCode": 308,
      "regex": "^(?!/_next)/products/product(?:/([^/]+?))(?:/)?$"
    },
    {
      "source": "/products",
      "destination": "/en/products",
      "statusCode": 308,
      "regex": "^(?!/_next)/products(?:/)?$"
    },
    {
      "source": "/cart",
      "destination": "/en/cart",
      "statusCode": 308,
      "regex": "^(?!/_next)/cart(?:/)?$"
    },
    {
      "source": "/orders",
      "destination": "/en/orders",
      "statusCode": 308,
      "regex": "^(?!/_next)/orders(?:/)?$"
    },
    {
      "source": "/profile",
